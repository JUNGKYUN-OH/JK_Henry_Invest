# Streamlit secrets 예시 파일
# 실제 사용 시 이 파일을 secrets.toml로 복사하고 값을 채우세요.
# secrets.toml은 .gitignore에 의해 커밋되지 않습니다.

[turso]
# Turso 대시보드 또는 CLI에서 확인:
#   URL:   turso db show <db-name>
#   Token: turso db tokens create <db-name>
url = "sqlite+libsql://<db-name>-<org-name>.turso.io?secure=true"
auth_token = "<your-turso-auth-token>"

# ── Google OIDC 로그인 설정 ────────────────────────────────────────────────────
# 설정 방법:
#   1. https://console.cloud.google.com → 새 프로젝트 생성
#   2. API 및 서비스 → OAuth 동의 화면 → 외부 선택 후 앱 이름 입력
#   3. 사용자 인증 정보 → OAuth 클라이언트 ID → 웹 애플리케이션
#   4. 승인된 리디렉션 URI: https://<your-app>.streamlit.app/oauth2callback
#   5. 발급된 클라이언트 ID와 보안 비밀을 아래에 입력
#
# [auth] 섹션이 없으면 로컬 개발 시 로그인 없이 바이패스됩니다.

[auth]
redirect_uri  = "https://<your-app>.streamlit.app/oauth2callback"
cookie_secret = "<32자 이상의 랜덤 문자열 — 예: python -c 'import secrets; print(secrets.token_hex(32))'>"

[auth.google]
client_id     = "<구글 클라이언트 ID>.apps.googleusercontent.com"
client_secret = "<구글 클라이언트 보안 비밀>"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# 접근을 허용할 Google 이메일 목록
# 빈 배열([])로 두면 모든 Google 계정 허용 (권장하지 않음)
[allowed_users]
emails = [
    "owner@gmail.com",
    "friend@gmail.com",
    "family@gmail.com",
]
